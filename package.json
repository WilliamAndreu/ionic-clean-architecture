{
  "name": "ionic-architecture",
  "version": "2.1.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "domain": "node scripts/generate-domain/index.js",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json}\"",
    "format:all": "prettier --write .",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@capacitor-community/sqlite": "7.0.1",
    "@capacitor/android": "7.4.4",
    "@capacitor/app": "7.0.2",
    "@capacitor/browser": "^7.0.3",
    "@capacitor/camera": "7.0.3",
    "@capacitor/core": "7.4.4",
    "@capacitor/device": "^7.0.2",
    "@capacitor/filesystem": "^7.1.5",
    "@capacitor/haptics": "7.0.2",
    "@capacitor/ios": "7.4.4",
    "@capacitor/keyboard": "7.0.2",
    "@capacitor/network": "7.0.2",
    "@capacitor/preferences": "7.0.2",
    "@capacitor/push-notifications": "7.0.2",
    "@capacitor/splash-screen": "7.0.2",
    "@capacitor/status-bar": "7.0.2",
    "@ionic/angular": "8.8.1",
    "@ngx-translate/core": "16.0.4",
    "@ngx-translate/http-loader": "8.0.0",
    "@xmldom/xmldom": "0.8.10",
    "ionicons": "8.0.13",
    "mustache": "4.2.0",
    "ngx-lottie": "20.0.0",
    "prompt-sync": "4.2.0",
    "rxjs": "7.8.2",
    "tesseract.js": "6.0.1",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/build": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/language-service": "^20.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "7.4.4",
    "@ionic/angular-toolkit": "^12.3.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@typescript-eslint/eslint-plugin": "6.14.0",
    "@typescript-eslint/parser": "6.14.0",
    "@typescript-eslint/utils": "^8.45.0",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.3",
    "postcss": "8.4.47",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "5.8.3",
    "vitest": "^3.1.1"
  },
  "description": "An Ionic project",
  "lint-staged": {
    "*.{ts,js}": [
      "./node_modules/.bin/eslint --max-warnings=0"
    ],
    "*.html": [
      "./node_modules/.bin/eslint --max-warnings=0"
    ],
    "*.{scss,css,json}": [
      "prettier --write"
    ]
  }
}
